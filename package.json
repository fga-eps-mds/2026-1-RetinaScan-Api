{
  "name": "retinascan-api",
  "version": "1.0.0",
  "description": "RetinaScan REST API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src -e ts --exec 'tsx --inspect --env-file=./env/.env.dev ./src/server.ts'",
    "test": "dotenv -e env/.env.test -- vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:file": "vitest run --reporter=verbose",
    "test:unit": "vitest run --project=unit",
    "test:integration": "dotenv -e env/.env.test -- vitest run --project=integration"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "fastify": "^5.8.4",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.20",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.3",
    "dotenv-cli": "^8.0.0",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.3"
  }
}
