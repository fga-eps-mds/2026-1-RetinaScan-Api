{
  "name": "retinascan-api",
  "version": "1.0.0",
  "description": "RetinaScan REST API",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc && tsc-alias -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src -e ts --exec \"tsx --inspect --env-file=./env/.env.dev ./src/server.ts\"",
    "test": "dotenv -e env/.env.test -- vitest run",
    "test:watch": "vitest",
    "test:coverage": "dotenv -e env/.env.test -- vitest run --coverage",
    "test:file": "dotenv -e env/.env.test -- vitest run --reporter=verbose",
    "test:unit": "dotenv -e env/.env.test -- vitest run --project=unit",
    "test:integration": "dotenv -e env/.env.test -- vitest run --project=integration",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "test:sonar": "npm run test:coverage",
    "sonar:scan": "npm run test:sonar",
    "db:generate": "dotenv -e env/.env.dev -- drizzle-kit generate",                                                    
    "db:migrate": "dotenv -e env/.env.dev -- tsx ./src/infra/database/drizzle/migrate.ts",                              
    "db:migrate:prod": "node ./dist/infra/database/drizzle/migrate.js",                                                 
    "db:push": "dotenv -e env/.env.dev -- drizzle-kit push",                                                     
    "db:studio": "dotenv -e env/.env.dev -- drizzle-kit studio",                                                 
    "db:drop": "dotenv -e env/.env.dev -- drizzle-kit drop"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/multipart": "^10.0.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "awilix": "^13.0.3",
    "better-auth": "^1.6.2",
    "cpf-cnpj-validator": "^1.0.3",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.4",
    "minio": "^8.0.7",
    "pg": "^8.13.1",
    "pino": "^10.3.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@testcontainers/postgresql": "^11.13.0",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@vitest/coverage-v8": "^4.1.3",
    "dotenv-cli": "^8.0.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "nodemon": "^3.1.14",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.8.2",
    "tsc-alias": "^1.8.16",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.1",
    "vitest": "^4.1.3"
  }
}
